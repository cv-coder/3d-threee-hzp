# ================================================
# 3D Packaging SaaS - Environment Configuration
# ================================================
# 请复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth.js 配置
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# ==================== 数据库配置 ====================
# PostgreSQL 连接信息
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=packaging_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# 数据库连接字符串 (自动生成，也可手动覆盖)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==================== MinIO (S3) 配置 ====================
# MinIO 服务器配置
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false

# MinIO 访问凭证
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO 应用访问密钥 (建议为应用单独创建)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# MinIO 公开访问 URL (用于生成公开文件链接)
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# Bucket 名称
MINIO_BUCKET_3D_MODELS=3d-models
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_BUCKET_LOGOS=logos
MINIO_BUCKET_SNAPSHOTS=snapshots

# ==================== Redis 配置 (可选) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ==================== 应用功能配置 ====================
# 文件上传限制 (MB)
MAX_FILE_SIZE_MB=50

# 允许的文件类型
ALLOWED_MODEL_EXTENSIONS=.glb,.gltf
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp

# 会话过期时间 (秒)
SESSION_MAX_AGE=2592000

# ==================== 邮件配置 (可选) ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# ==================== 开发工具 ====================
# 启用调试日志
DEBUG_SQL=false
DEBUG_S3=false
